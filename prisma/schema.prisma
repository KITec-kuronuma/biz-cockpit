// biz-cockpit データモデル
// 上長仕様（v1.0）準拠：Client / Contact / Project / Invoice / Payment / CostMonthly / ProjectContact / Setting
// 補助：User（権限管理）/ Activity（活動履歴）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 取引先企業
model Client {
  id        String                @id @default(cuid())
  name      String
  address   String?
  phone     String?
  fax       String?
  website   String?
  industry  String?
  note      String?
  contacts  Contact[]
  projects  Project[]
  budgets   ClientMonthlyBudget[]
  licenses  LicenseContract[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

// ライセンス契約（独立モデル：案件とは別に管理、任意で案件にリンク可）
model LicenseContract {
  id                   String                    @id @default(cuid())
  clientId             String
  client               Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId            String?
  project              Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  productName          String
  planName             String?
  serviceType          String                    @default("LICENSE") // LICENSE / MAINTENANCE
  initialMonthlyAmount Int                       @default(0)
  monthlyAmount        Int
  billingCycle         String                    @default("MONTHLY")
  startDate            DateTime
  endDate              DateTime?
  nextRenewalDate      DateTime?
  renewalType          String                    @default("MANUAL")
  status               String                    @default("ACTIVE")
  licenseAgreement     String?                   // 使用許諾書（フリー入力）
  memorandum           String?                   // 覚書（フリー入力）
  quoteSentMonth       String?                   // 見積書送付月（YYYY-MM）
  note                 String?
  schedules            LicenseMonthlySchedule[]
  actuals              LicenseMonthlyActual[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
}

// ライセンス計上予定額の変更履歴（適用開始月ベース）
model LicenseMonthlySchedule {
  id             String          @id @default(cuid())
  licenseId      String
  license        LicenseContract @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  effectiveMonth String          // YYYY-MM - この月以降に適用
  amount         Int
  note           String?
  createdAt      DateTime        @default(now())

  @@index([licenseId, effectiveMonth])
}

// ライセンス月次実績
model LicenseMonthlyActual {
  id        String          @id @default(cuid())
  licenseId String
  license   LicenseContract @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  yearMonth String          // YYYY-MM
  amount    Int
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([licenseId, yearMonth])
}

// 取引先 × 月別 予算（当期予算の源泉）
model ClientMonthlyBudget {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  yearMonth String   // YYYY-MM
  amount    Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, yearMonth])
}

// 担当者・関係者
model Contact {
  id        String           @id @default(cuid())
  clientId  String
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?
  // 補助：送付区分タグ（カンマ区切り：quote,invoice,contract,decision）
  sendFlags String?
  projects  ProjectContact[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// 案件（中核）
model Project {
  id               String                    @id @default(cuid())
  clientId         String
  client           Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  title            String
  contractDate     DateTime?
  deliveryDate     DateTime?
  contractAmount   Int                       @default(0)
  taxRate          Int                       @default(10)
  licenseFee       Int?
  licenseStartDate DateTime?
  licenseCycle     String? // MONTHLY / YEARLY / ONE_TIME
  status           String                    @default("LEAD")
  progress         String                    @default("NOT_STARTED")
  detailPhase      String?
  initialForecast  String?
  note             String?
  invoices         Invoice[]
  costs            CostMonthly[]
  forecasts        ProjectMonthlyForecast[]
  licenses         LicenseContract[]
  contacts         ProjectContact[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
}

// 案件別 月次売上見込み（期初予想 + 現状見込みの2軸）
model ProjectMonthlyForecast {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  yearMonth     String   // YYYY-MM
  initialAmount Int      @default(0) // 期初予想（登録時にロック）
  amount        Int      // 現状見込み（随時更新可）
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, yearMonth])
}

// 請求（1案件 1:多）
model Invoice {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceDate DateTime
  amount      Int
  dueDate     DateTime?
  status      String    @default("NOT_ISSUED") // NOT_ISSUED/ISSUED/PAID
  payments    Payment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 入金（1請求 1:多）
model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentDate DateTime
  amount      Int
  createdAt   DateTime @default(now())
}

// 月次原価
model CostMonthly {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  yearMonth String
  amount    Int
  category  String?
  createdAt DateTime @default(now())
}

// 案件関係者（多対多中間）
model ProjectContact {
  projectId String
  contactId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([projectId, contactId])
}

// アプリ設定（単一行）
model Setting {
  id                   String @id @default("singleton")
  fiscalStartMonth     Int    @default(4)
  targetContractAmount Int    @default(100000000)
  targetContractCount  Int    @default(5)
  defaultRevenueBasis  String @default("DELIVERY")
  annualBudgetRevenue  Int    @default(120000000)
  taxRate              Int    @default(10)
}

// 会計年度（年度ごとに開始月・終了月を柔軟設定）
model FiscalYear {
  id        String   @id @default(cuid())
  label     String   @unique  // 例：「2026年度」
  startYM   String                // 開始年月 YYYY-MM 例：「2026-04」
  endYM     String                // 終了年月 YYYY-MM 例：「2026-12」
  isCurrent Boolean  @default(false) // 現在の年度（1件のみtrue）
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 補助：ユーザー（権限管理）
model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  department String?
  role       String   @default("MEMBER") // ADMIN/MANAGER/MEMBER
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// 補助：活動履歴
model Activity {
  id          String    @id @default(cuid())
  date        DateTime
  type        String // CALL/EMAIL/VISIT/ONLINE
  clientId    String?
  contactId   String?
  projectId   String?
  content     String
  nextAction  String?
  nextDate    DateTime?
  ownerUserId String?
  createdAt   DateTime  @default(now())
}
